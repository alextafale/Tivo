# ──────────────────────────────────────────────────────────────
#  TIVO Backend — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ──────────────────────────────────────────────────────────────

# === Base de datos PostgreSQL ===
DATABASE_URL=postgresql://tivo:tivopass@localhost:5432/tivo_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=tivo
DB_PASSWORD=tivopass
DB_NAME=tivo_db

# === Qwen / DashScope ===
# Obtén tu key en: https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXX
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# === Seguridad ===
JWT_SECRET=tivo-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# === Servidor ===
PORT=3000
NODE_ENV=development

# === CORS — origen del app Expo ===
CORS_ORIGIN=http://localhost:8081

# === Nombre del negocio (contexto para la IA) ===
BUSINESS_NAME=Mi Negocio TIVO
